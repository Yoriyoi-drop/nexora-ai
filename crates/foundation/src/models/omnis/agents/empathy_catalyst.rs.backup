                user_preferences: UserPreferences {
                    communication_style_preference: CommunicationStylePreference::FriendlyStyle,
                    emotional_support_level: EmotionalSupportLevel::ModerateSupport,
                    response_length_preference: ResponseLengthPreference::Moderate,
