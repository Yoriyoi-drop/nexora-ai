#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EnvironmentalContext {
    /// Physical environment
    pub physical_environment: PhysicalEnvironment,
    /// Social environment
    pub social_environment: SocialEnvironment,
    /// Temporal context
    pub temporal_context: TemporalContext,
}

/// Physical Environment
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PhysicalEnvironment {
    /// Location
    pub location: Option<String>,
    /// Time of day
    pub time_of_day: Option<String>,
    /// Weather conditions
    pub weather_conditions: Option<String>,
}

/// Social Environment
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct SocialEnvironment {
    /// Social setting
    pub social_setting: Option<String>,
    /// Social roles
    pub social_roles: Vec<String>,
    /// Social relationships
    pub social_relationships: Vec<String>,
}

/// Temporal Context
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TemporalContext {
    /// Current time
    pub current_time: chrono::DateTime<chrono::Utc>,
    /// Time zone
    pub time_zone: Option<String>,
    /// Season
    pub season: Option<String>,
}

/// Emotional Context
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmotionalContext {
    /// Current emotional state
    pub current_emotional_state: EmotionalState,
    /// Emotional history
    pub emotional_history: Vec<EmotionalHistoryRecord>,
    /// Emotional triggers
    pub emotional_triggers: Vec<EmotionalTrigger>,
}

/// Emotional State
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmotionalState {
    /// Primary emotions
    pub primary_emotions: Vec<Emotion>,
    /// Secondary emotions
    pub secondary_emotions: Vec<Emotion>,
    /// Emotional intensity
    pub emotional_intensity: f32,
    /// Emotional valence
    pub emotional_valence: EmotionValence,
}

/// Emotional History Record
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmotionalHistoryRecord {
    /// Record ID
    pub record_id: String,
    /// Timestamp
    pub timestamp: chrono::DateTime<chrono::Utc>,
    /// Emotional state
    pub emotional_state: EmotionalState,
    /// Triggering event
    pub triggering_event: Option<String>,
}

/// Emotional Trigger
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmotionalTrigger {
    /// Trigger ID
    pub trigger_id: String,
    /// Trigger description
    pub trigger_description: String,
    /// Trigger type
    pub trigger_type: TriggerType,
    /// Trigger strength
    pub trigger_strength: f32,
}

/// Trigger Type
#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum TriggerType {
    /// Internal trigger
    InternalTrigger,
    /// External trigger
    ExternalTrigger,
    /// Social trigger
    SocialTrigger,
    /// Environmental trigger
    EnvironmentalTrigger,
}

/// Response Requirements
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ResponseRequirements {
    /// Response type
    pub response_type:ResponseType,
    /// Response length
    pub response_length: ResponseLengthPreference,
    /// Response tone
    pub response_tone: TonePreference,
    /// Response depth
    pub response_depth: ResponseDepth,
}

/// Response Type
#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum ResponseType {
    /// Informational response
    InformationalResponse,
    /// Emotional support response
    EmotionalSupportResponse,
    /// Problem-solving response
    ProblemSolvingResponse,
    /// Validation response
    ValidationResponse,
}

/// Response Depth
#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum ResponseDepth {
    /// Surface level
    SurfaceLevel,
    /// Moderate depth
    ModerateDepth,
    /// Deep level
    DeepLevel,
    /// Very deep level
    VeryDeepLevel,
}

/// Empathy Catalyst Task Output
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmpathyCatalystTaskOutput {
    /// Empathetic response
    pub empathetic_response: EmpatheticResponse,
    /// Emotional analysis results
    pub emotional_analysis_results: EmotionalAnalysisResults,
    /// Personalization details
    pub personalization_details: PersonalizationDetails,
    /// Response quality metrics
    pub response_quality_metrics: ResponseQualityMetrics,
}

/// Empathetic Response
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmpatheticResponse {
    /// Response ID
    pub response_id: String,
    /// Response text
    pub response_text: String,
    /// Response type
    pub response_type: ResponseType,
    /// Response tone
    pub response_tone: TonePreference,
    /// Empathy level
    pub empathy_level: EmpathyLevel,
}

/// Empathy Level
#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum EmpathyLevel {
    /// Basic empathy
    BasicEmpathy,
    /// Moderate empathy
    ModerateEmpathy,
    /// Deep empathy
    DeepEmpathy,
    /// Profound empathy
    ProfoundEmpathy,
}

/// Emotional Analysis Results
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EmotionalAnalysisResults {
    /// Detected emotions
    pub detected_emotions: Vec<Emotion>,
    /// Sentiment analysis
    pub sentiment_analysis: SentimentAnalysisResult,
    /// Emotional state assessment
    pub emotional_state_assessment: EmotionalStateAssessment,
    /// Confidence scores
    pub confidence_scores: HashMap<String, f32>,
}

/// Sentiment Analysis Result
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct SentimentAnalysisResult {
    /// Overall sentiment
    pub overall_sentiment: f32,
    /// Sentiment category
    pub sentiment_category: SentimentCategory,
    /// Aspect sentiments
    pub aspect_sentiments: HashMap<String, f32>,
}

/// Sentiment Category
#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum SentimentCategory {
    /// Positive
    Positive,
    /// Negative
    Negative,
    /// Neutral
    Neutral,
    /// Mixed
    Mixed,
}

/// Personalization Details
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PersonalizationDetails {
    /// Personalization factors
    pub personalization_factors: Vec<PersonalizationFactor>,
    /// Adaptation decisions
    pub adaptation_decisions: Vec<AdaptationDecision>,
    /// User preferences applied
    pub user_preferences_applied: Vec<String>,
}

/// Personalization Factor
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PersonalizationFactor {
    /// Factor ID
    pub factor_id: String,
    /// Factor name
    pub factor_name: String,
    /// Factor influence
    pub factor_influence: f32,
    /// Factor value
    pub factor_value: String,
}

/// Adaptation Decision
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct AdaptationDecision {
    /// Decision ID
    pub decision_id: String,
    /// Decision description
    pub decision_description: String,
    /// Decision rationale
    pub decision_rationale: String,
    /// Decision impact
    pub decision_impact: f32,
}

/// Response Quality Metrics
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ResponseQualityMetrics {
    /// Overall quality score
    pub overall_quality_score: f32,
    /// Empathy score
    pub empathy_score: f32,
    /// Relevance score
    pub relevance_score: f32,
    /// Appropriateness score
    pub appropriateness_score: f32,
    /// Coherence score
    pub coherence_score: f32,
}

impl Default for EmpathyCatalystConfig {
    fn default() -> Self {
        Self {
            base_config: BaseAgentConfig::default(),
            empathy_model: EmpathyModel::IntegratedEmpathyModel {
                models: vec![
                    EmpathyModel::CognitiveEmpathyModel,
                    EmpathyModel::AffectiveEmpathyModel,
                    EmpathyModel::CompassionateEmpathyModel,
