                    target_thresholds: HashMap::from([
                        ("empathy_score".to_string(), 0.8),
                        ("relevance_score".to_string(), 0.85),
                    ]),
                    excellence_thresholds: HashMap::from([
                        ("empathy_score".to_string(), 0.9),
                        ("relevance_score".to_string(), 0.95),
                    ]),
                },
            },
        }
    }
}

impl Default for EmpathyCatalystAgent {
    fn default() -> Self {
        Self {
            config: EmpathyCatalystConfig::default(),
            empathy_capabilities: EmpathyCapabilities::default(),
            emotional_analysis: EmotionalAnalysis::default(),
            empathetic_response_generation: EmpatheticResponseGeneration::default(),
            status: AgentStatus::Idle,
            metrics: AgentMetrics {
                tasks_processed: 0,
                avg_processing_time: 0.0,
                success_rate: 1.0,
                current_load: 0.0,
                last_activity: chrono::Utc::now(),
            },
        }
    }
}

#[async_trait]
impl BaseAgent for EmpathyCatalystAgent {
    type Config = EmpathyCatalystConfig;
    type Input = EmpathyCatalystTaskInput;
    type Output = EmpathyCatalystTaskOutput;

    async fn process(&self, input: Self::Input) -> AgentResult<Self::Output> {
        let start_time = std::time::Instant::now();
        
        // Validate input
        self.validate_input(&input)?;
        
        // Analyze emotional context
        let emotional_analysis_results = self.analyze_emotional_context(&input).await?;
        
        // Generate empathetic response
        let empathetic_response = self.generate_empathetic_response(&input, &emotional_analysis_results).await?;
        
        // Apply personalization
        let personalization_details = self.apply_personalization(&input, &empathetic_response).await?;
        
        // Assess response quality
        let response_quality_metrics = self.assess_response_quality(&input, &empathetic_response, &emotional_analysis_results).await?;
        
        // Build output
        let output = EmpathyCatalystTaskOutput {
            empathetic_response,
            emotional_analysis_results,
            personalization_details,
            response_quality_metrics,
        };
        
        let processing_time = start_time.elapsed().as_millis() as u64;
        
        Ok(output)
    }

    fn agent_id(&self) -> &str {
        &self.config.base_config.agent_id
    }

    fn get_status(&self) -> AgentStatus {
        self.status.clone()
    }

    fn get_capabilities(&self) -> Vec<AgentCapability> {
        vec![
            AgentCapability {
                name: "empathy_catalyst".to_string(),
                description: "Deep emotional understanding and empathetic response generation".to_string(),
                version: "1.0.0".to_string(),
                input_types: vec!["user_input".to_string(), "emotional_context".to_string()],
                output_types: vec!["empathetic_response".to_string(), "emotional_analysis".to_string()],
                metrics: crate::shared::agent_types::CapabilityMetrics {
                    accuracy: 0.88,
                    avg_latency: 2000.0,
                    resource_usage: 0.6,
                    reliability: 0.91,
                },
            },
        ]
    }

    fn get_metrics(&self) -> AgentMetrics {
        self.metrics.clone()
    }

    async fn initialize(&mut self, config: Self::Config) -> AgentResult<()> {
        self.config = config;
        self.status = AgentStatus::Idle;
        Ok(())
    }

    async fn shutdown(&mut self) -> AgentResult<()> {
        self.status = AgentStatus::Disabled;
        Ok(())
    }
}

impl EmpathyCatalystAgent {
    /// Create a new Empathy Catalyst Agent
    pub fn new(config: EmpathyCatalystConfig) -> Self {
        Self {
            config,
            empathy_capabilities: EmpathyCapabilities::default(),
            emotional_analysis: EmotionalAnalysis::default(),
            empathetic_response_generation: EmpatheticResponseGeneration::default(),
            status: AgentStatus::Idle,
            metrics: AgentMetrics {
                tasks_processed: 0,
                avg_processing_time: 0.0,
                success_rate: 1.0,
                current_load: 0.0,
                last_activity: chrono::Utc::now(),
            },
        }
    }

    /// Validate empathy catalyst task input
    fn validate_input(&self, input: &EmpathyCatalystTaskInput) -> AgentResult<()> {
        if input.user_input.is_empty() {
            return Err(crate::shared::agent_types::AgentError::InvalidInput(
                "User input cannot be empty".to_string()
            ));
        }
        
        Ok(())
    }

    /// Analyze emotional context
    async fn analyze_emotional_context(&self, input: &EmpathyCatalystTaskInput) -> AgentResult<EmotionalAnalysisResults> {
        // Detect emotions from user input
        let detected_emotions = self.detect_emotions(&input.user_input).await?;
        
        // Analyze sentiment
        let sentiment_analysis = self.analyze_sentiment(&input.user_input).await?;
        
        // Assess emotional state
        let emotional_state_assessment = self.assess_emotional_state(&input.emotional_context.current_emotional_state).await?;
        
        // Calculate confidence scores
        let mut confidence_scores = HashMap::new();
        confidence_scores.insert("emotion_detection".to_string(), 0.85);
        confidence_scores.insert("sentiment_analysis".to_string(), 0.8);
        confidence_scores.insert("state_assessment".to_string(), 0.75);
        
        Ok(EmotionalAnalysisResults {
            detected_emotions,
            sentiment_analysis,
            emotional_state_assessment,
            confidence_scores,
        })
    }

    /// Detect emotions from text
    async fn detect_emotions(&self, text: &str) -> AgentResult<Vec<Emotion>> {
        let mut emotions = Vec::new();
        
        // Simple emotion detection based on keywords
        let text_lower = text.to_lowercase();
        
        if text_lower.contains("happy") || text_lower.contains("joy") || text_lower.contains("excited") {
            emotions.push(Emotion {
                emotion_id: "joy_001".to_string(),
                emotion_name: "Joy".to_string(),
                emotion_valence: EmotionValence::Positive,
                emotion_arousal: 0.8,
                emotion_intensity: 0.7,
            });
        }
        
        if text_lower.contains("sad") || text_lower.contains("depressed") || text_lower.contains("down") {
            emotions.push(Emotion {
                emotion_id: "sadness_001".to_string(),
                emotion_name: "Sadness".to_string(),
                emotion_valence: EmotionValence::Negative,
                emotion_arousal: 0.6,
                emotion_intensity: 0.6,
            });
        }
        
        if text_lower.contains("angry") || text_lower.contains("frustrated") || text_lower.contains("upset") {
            emotions.push(Emotion {
                emotion_id: "anger_001".to_string(),
                emotion_name: "Anger".to_string(),
                emotion_valence: EmotionValence::Negative,
                emotion_arousal: 0.9,
                emotion_intensity: 0.8,
            });
        }
        
        if text_lower.contains("anxious") || text_lower.contains("worried") || text_lower.contains("nervous") {
            emotions.push(Emotion {
                emotion_id: "fear_001".to_string(),
                emotion_name: "Fear".to_string(),
                emotion_valence: EmotionValence::Negative,
                emotion_arousal: 0.7,
                emotion_intensity: 0.6,
            });
        }
        
        Ok(emotions)
    }

    /// Analyze sentiment
    async fn analyze_sentiment(&self, text: &str) -> AgentResult<SentimentAnalysisResult> {
        let text_lower = text.to_lowercase();
        
        let positive_words = vec!["happy", "good", "great", "wonderful", "excellent"];
        let negative_words = vec!["sad", "bad", "terrible", "awful", "horrible"];
        
        let positive_count = positive_words.iter().filter(|&word| text_lower.contains(word)).count() as f32;
        let negative_count = negative_words.iter().filter(|&word| text_lower.contains(word)).count() as f32;
        
        let total_words = positive_count + negative_count;
        let overall_sentiment = if total_words > 0.0 {
            (positive_count - negative_count) / total_words
        } else {
            0.0
        };
        
        let sentiment_category = if overall_sentiment > 0.1 {
            SentimentCategory::Positive
        } else if overall_sentiment < -0.1 {
            SentimentCategory::Negative
        } else {
            SentimentCategory::Neutral
        };
        
        let mut aspect_sentiments = HashMap::new();
        aspect_sentiments.insert("overall".to_string(), overall_sentiment);
        
        Ok(SentimentAnalysisResult {
            overall_sentiment,
            sentiment_category,
            aspect_sentiments,
        })
    }

    /// Assess emotional state
    async fn assess_emotional_state(&self, emotional_state: &EmotionalState) -> AgentResult<EmotionalStateAssessment> {
        let state_classification = StateClassification {
            classification_methods: vec![
                ClassificationMethod::RuleBasedClassification,
            ],
            state_categories: vec![
                StateCategory {
                    category_id: "current".to_string(),
                    category_name: "Current State".to_string(),
                    category_description: "Current emotional state".to_string(),
                    characteristic_emotions: emotional_state.primary_emotions.iter().map(|e| e.emotion_name.clone()).collect(),
                },
            ],
            classification_confidence: 0.8,
        };
        
        let state_intensity_measurement = StateIntensityMeasurement {
            measurement_scale: MeasurementScale {
                scale_type: ScaleType::LinearScale,
                scale_range: (0.0, 1.0),
                scale_granularity: 0.1,
            },
            intensity_factors: vec![
                IntensityFactor {
                    factor_id: "intensity_001".to_string(),
                    factor_name: "Emotional Intensity".to_string(),
                    factor_weight: 1.0,
                    factor_measurement: emotional_state.emotional_intensity,
                },
            ],
            intensity_normalization: true,
        };
        
        let state_stability_assessment = StateStabilityAssessment {
            stability_metrics: vec![
                StabilityMetric {
                    metric_id: "stability_001".to_string(),
                    metric_name: "Emotional Stability".to_string(),
                    metric_value: 0.7,
                    metric_threshold: 0.6,
                },
            ],
            volatility_measurement: 0.3,
            predictability_assessment: 0.6,
        };
        
        let state_transition_prediction = StateTransitionPrediction {
            prediction_methods: vec![
                PredictionMethod::MarkovChain,
            ],
            transition_probabilities: HashMap::new(),
            prediction_confidence: 0.7,
        };
        
        Ok(EmotionalStateAssessment {
            state_classification,
            state_intensity_measurement,
            state_stability_assessment,
            state_transition_prediction,
        })
    }

    /// Generate empathetic response
    async fn generate_empathetic_response(&self, input: &EmpathyCatalystTaskInput, emotional_analysis: &EmotionalAnalysisResults) -> AgentResult<EmpatheticResponse> {
        let response_id = format!("response_{}", chrono::Utc::now().timestamp());
        
        // Determine response type based on emotional analysis
        let response_type = if emotional_analysis.sentiment_analysis.overall_sentiment < -0.2 {
            ResponseType::EmotionalSupportResponse
        } else if emotional_analysis.sentiment_analysis.overall_sentiment > 0.2 {
            ResponseType::ValidationResponse
        } else {
            ResponseType::InformationalResponse
        };
        
        // Generate response text based on emotions
        let response_text = self.generate_response_text(&input.user_input, emotional_analysis).await?;
        
        // Determine response tone
        let response_tone = match response_type {
            ResponseType::EmotionalSupportResponse => TonePreference::Supportive,
            ResponseType::ValidationResponse => TonePreference::Encouraging,
            _ => TonePreference::Neutral,
        };
        
        // Calculate empathy level
        let empathy_level = if emotional_analysis.detected_emotions.len() > 0 {
            EmpathyLevel::DeepEmpathy
        } else {
            EmpathyLevel::ModerateEmpathy
        };
        
        Ok(EmpatheticResponse {
            response_id,
            response_text,
            response_type,
            response_tone,
            empathy_level,
        })
    }

    /// Generate response text
    async fn generate_response_text(&self, user_input: &str, emotional_analysis: &EmotionalAnalysisResults) -> AgentResult<String> {
        let mut response = String::new();
        
        // Acknowledge the user's feelings
        if !emotional_analysis.detected_emotions.is_empty() {
            response.push_str("I can see that you're feeling ");
            for (i, emotion) in emotional_analysis.detected_emotions.iter().enumerate() {
                if i > 0 {
                    response.push_str(" and ");
                }
                response.push_str(&emotion.emotion_name);
            }
            response.push_str(". ");
        }
        
        // Add empathetic validation
        response.push_str("It's completely valid to feel this way, and I want you to know that your feelings are important. ");
        
        // Add supportive message
        if emotional_analysis.sentiment_analysis.overall_sentiment < -0.2 {
            response.push_str("I'm here to support you through this difficult time. ");
            response.push_str("Remember that challenging emotions are temporary, and you have the strength to work through them. ");
            response.push_str("What would be most helpful for you right now?");
        } else if emotional_analysis.sentiment_analysis.overall_sentiment > 0.2 {
            response.push_str("It's wonderful to see you in such a positive state! ");
            response.push_str("I hope you can savor these good feelings and share them with others who care about you. ");
            response.push_str("What's bringing you this joy today?");
        } else {
            response.push_str("I'm here to listen and support you. ");
            response.push_str("Whatever you're going through, know that you're not alone in this experience. ");
            response.push_str("How can I best assist you today?");
        }
        
        Ok(response)
    }

    /// Apply personalization
    async fn apply_personalization(&self, input: &EmpathyCatalystTaskInput, response: &EmpatheticResponse) -> AgentResult<PersonalizationDetails> {
        let mut personalization_factors = Vec::new();
        let mut adaptation_decisions = Vec::new();
        let mut user_preferences_applied = Vec::new();
        
        // Apply communication style preference
        personalization_factors.push(PersonalizationFactor {
            factor_id: "factor_001".to_string(),
            factor_name: "Communication Style".to_string(),
            factor_influence: 0.3,
            factor_value: format!("{:?}", input.response_requirements.response_tone),
        });
        
        user_preferences_applied.push("Communication style applied".to_string());
        
        // Apply response length preference
        personalization_factors.push(PersonalizationFactor {
            factor_id: "factor_002".to_string(),
            factor_name: "Response Length".to_string(),
            factor_influence: 0.2,
            factor_value: format!("{:?}", input.response_requirements.response_length),
        });
        
        user_preferences_applied.push("Response length preference applied".to_string());
        
        // Cultural adaptation
        if !input.user_context.user_profile.demographic_information.cultural_background.is_none() {
            adaptation_decisions.push(AdaptationDecision {
                decision_id: "decision_001".to_string(),
                decision_description: "Cultural context adaptation".to_string(),
                decision_rationale: "Adapted response based on cultural background".to_string(),
                decision_impact: 0.2,
            });
        }
        
        Ok(PersonalizationDetails {
            personalization_factors,
            adaptation_decisions,
            user_preferences_applied,
        })
    }

    /// Assess response quality
    async fn assess_response_quality(&self, input: &EmpathyCatalystTaskInput, response: &EmpatheticResponse, emotional_analysis: &EmotionalAnalysisResults) -> AgentResult<ResponseQualityMetrics> {
        let empathy_score = self.calculate_empathy_score(response, emotional_analysis).await?;
        let relevance_score = self.calculate_relevance_score(&input.user_input, &response.response_text).await?;
        let appropriateness_score = self.calculate_appropriateness_score(response, &input.response_requirements).await?;
        let coherence_score = self.calculate_coherence_score(&response.response_text).await?;
        
        let overall_quality_score = (empathy_score + relevance_score + appropriateness_score + coherence_score) / 4.0;
        
        Ok(ResponseQualityMetrics {
            overall_quality_score,
            empathy_score,
            relevance_score,
            appropriateness_score,
            coherence_score,
        })
    }

    /// Calculate empathy score
    async fn calculate_empathy_score(response: &EmpatheticResponse, emotional_analysis: &EmotionalAnalysisResults) -> AgentResult<f32> {
        let mut score = 0.5; // Base score
        
        // Increase score based on empathy level
        match response.empathy_level {
            EmpathyLevel::BasicEmpathy => score += 0.1,
            EmpathyLevel::ModerateEmpathy => score += 0.2,
            EmpathyLevel::DeepEmpathy => score += 0.3,
            EmpathyLevel::ProfoundEmpathy => score += 0.4,
        }
        
        // Increase score if response acknowledges emotions
        if response.response_text.to_lowercase().contains("feeling") {
            score += 0.2;
        }
        
        Ok(score.min(1.0))
    }

    /// Calculate relevance score
    async fn calculate_relevance_score(&self, user_input: &str, response_text: &str) -> AgentResult<f32> {
        let user_words: Vec<String> = user_input.to_lowercase().split_whitespace().map(|s| s.to_string()).collect();
        let response_words: Vec<String> = response_text.to_lowercase().split_whitespace().map(|s| s.to_string()).collect();
        
        let common_words = user_words.iter().filter(|word| response_words.contains(word)).count();
        
        let relevance_score = if user_words.len() > 0 {
            common_words as f32 / user_words.len() as f32
        } else {
            0.0
        };
        
        Ok(relevance_score)
    }

    /// Calculate appropriateness score
    async fn calculate_appropriateness_score(response: &EmpatheticResponse, requirements: &ResponseRequirements) -> AgentResult<f32> {
        let mut score = 0.5; // Base score
        
        // Check tone appropriateness
        match (response.response_tone, &requirements.response_tone) {
            (TonePreference::Supportive, TonePreference::Supportive) => score += 0.3,
            (TonePreference::Encouraging, TonePreference::Encouraging) => score += 0.3,
            (TonePreference::Calming, TonePreference::Calming) => score += 0.3,
            (TonePreference::Empowering, TonePreference::Empowering) => score += 0.3,
            _ => score += 0.1, // Partial match
        }
        
        Ok(score.min(1.0))
    }

    /// Calculate coherence score
    async fn calculate_coherence_score(response_text: &str) -> AgentResult<f32> {
        let words: Vec<&str> = response_text.split_whitespace().collect();
        
        // Simple coherence check based on sentence structure
        let sentence_count = response_text.matches('.').count();
        let word_count = words.len();
        
        let coherence_score = if word_count > 0 && sentence_count > 0 {
            (sentence_count as f32 / word_count as f32).min(0.3) * 3.33 // Normalize to 0-1
        } else {
            0.5
        };
        
        Ok(coherence_score)
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_empathy_catalyst_agent_creation() {
        let agent = EmpathyCatalystAgent::default();
        assert_eq!(agent.agent_id(), "default_agent");
        assert!(matches!(agent.get_status(), AgentStatus::Idle));
    }

    #[tokio::test]
    async fn test_empathy_catalyst_task_processing() {
        let agent = EmpathyCatalystAgent::default();
        let input = EmpathyCatalystTaskInput {
            user_input: "I'm feeling really sad today because I lost my job".to_string(),
            user_context: UserContext {
                user_profile: UserProfile {
                    user_id: "user_001".to_string(),
                    demographic_information: DemographicInformation {
                        age: Some(30),
                        gender: Some("Female".to_string()),
                        cultural_background: Some("American".to_string()),
                        language_preferences: vec!["English".to_string()],
                    },
                    personality_traits: vec![],
                    communication_preferences: CommunicationPreferences {
                        preferred_tone: TonePreference::Supportive,
                        response_length: ResponseLengthPreference::Moderate,
                        formality_level: FormalityLevel::Informal,
                        directness_level: DirectnessLevel::Direct,
                    },
                    emotional_patterns: vec![],
                },
                session_context: SessionContext {
                    session_id: "session_001".to_string(),
                    session_start_time: chrono::Utc::now(),
                    interaction_history: vec![],
                    session_goals: vec!["emotional_support".to_string()],
                },
                environmental_context: EnvironmentalContext {
                    physical_environment: PhysicalEnvironment {
                        location: Some("Home".to_string()),
                        time_of_day: Some("Evening".to_string()),
                        weather_conditions: Some("Rainy".to_string()),
                    },
                    social_environment: SocialEnvironment {
                        social_setting: Some("Alone".to_string()),
                        social_roles: vec!["Employee".to_string()],
                        social_relationships: vec!["Family".to_string()],
                    },
                    temporal_context: TemporalContext {
                        current_time: chrono::Utc::now(),
                        time_zone: Some("EST".to_string()),
                        season: Some("Winter".to_string()),
                    },
                },
            },
            emotional_context: EmotionalContext {
                current_emotional_state: EmotionalState {
                    primary_emotions: vec![
                        Emotion {
                            emotion_id: "sad_001".to_string(),
                            emotion_name: "Sadness".to_string(),
                            emotion_valence: EmotionValence::Negative,
                            emotion_arousal: 0.6,
                            emotion_intensity: 0.7,
                        },
                    ],
                    secondary_emotions: vec![],
                    emotional_intensity: 0.7,
                    emotional_valence: EmotionValence::Negative,
                },
                emotional_history: vec![],
                emotional_triggers: vec![
                    EmotionalTrigger {
                        trigger_id: "trigger_001".to_string(),
                        trigger_description: "Job loss".to_string(),
                        trigger_type: TriggerType::ExternalTrigger,
                        trigger_strength: 0.8,
                    },
                ],
            },
            response_requirements: ResponseRequirements {
                response_type: ResponseType::EmotionalSupportResponse,
                response_length: ResponseLengthPreference::Moderate,
                response_tone: TonePreference::Supportive,
                response_depth: ResponseDepth::ModerateDepth,
            },
        };

        let result = agent.process(input).await;
        assert!(result.is_ok());
        
        let output = result.unwrap();
        assert!(!output.empathetic_response.response_text.is_empty());
        assert!(!output.emotional_analysis_results.detected_emotions.is_empty());
        assert!(!output.personalization_details.personalization_factors.is_empty());
        assert!(output.response_quality_metrics.overall_quality_score > 0.0);
    }

    #[test]
    fn test_emotion_detection() {
        let agent = EmpathyCatalystAgent::default();
        
        let text = "I am so happy and excited today!";
        let result = tokio_test::block_on(agent.detect_emotions(text));
        assert!(result.is_ok());
        
        let emotions = result.unwrap();
        assert!(!emotions.is_empty());
        assert!(emotions.iter().any(|e| e.emotion_name == "Joy"));
    }

    #[test]
    fn test_sentiment_analysis() {
        let agent = EmpathyCatalystAgent::default();
        
        let text = "This is a wonderful and amazing day!";
        let result = tokio_test::block_on(agent.analyze_sentiment(text));
        assert!(result.is_ok());
        
        let sentiment = result.unwrap();
        assert!(sentiment.overall_sentiment > 0.0);
        assert!(matches!(sentiment.sentiment_category, SentimentCategory::Positive));
    }

    #[test]
    fn test_empathy_model() {
        let config = EmpathyCatalystConfig {
            empathy_model: EmpathyModel::CompassionateEmpathyModel,
            ..Default::default()
        };
        let agent = EmpathyCatalystAgent::new(config);
        
        assert!(matches!(agent.config.empathy_model, EmpathyModel::CompassionateEmpathyModel));
    }
}
