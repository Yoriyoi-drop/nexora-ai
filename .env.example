# Nexora AI Environment Configuration
# Copy this file to .env and fill in your values

# Server
NEXORA_HOST=127.0.0.1
NEXORA_PORT=8080
NEXORA_ENABLE_TLS=false

# API Authentication
NEXORA_API_KEYS=
NEXORA_ENABLE_AUTH=false

# CORS
NEXORA_CORS_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexora
POSTGRES_USER=nexora
POSTGRES_PASSWORD=change_this_password

# MongoDB
MONGODB_URI=mongodb://nexora:change_this_password@localhost:27017/nexora

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# MinIO S3
MINIO_ROOT_USER=nexora
MINIO_ROOT_PASSWORD=change_this_password
MINIO_ENDPOINT=http://localhost:9000

# InfluxDB
INFLUXDB_TOKEN=change_this_token
